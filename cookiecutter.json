{
  "project_name": "My Project",
  "project_slug": "{{ cookiecutter.project_name.lower().replace(' ', '-') }}",
  "project_description": "A short description of the project.",
  "owner": "My Organization",
  "repo_namespace": "{{ cookiecutter.owner.lower().replace(' ', '-') }}",
  "git_service": [
    "GitHub",
    "GitLab",
    "Bitbucket",
    "Azure DevOps"
  ],
  "__repo_base_urls": {
    "GitHub": "https://github.com",
    "GitLab": "https://gitlab.com",
    "Bitbucket": "https://bitbucket.org",
    "Azure DevOps": "https://dev.azure.com"
  },
  "__repo_paths": {
    "GitHub": "{{ cookiecutter.repo_namespace }}/{{ cookiecutter.project_slug }}",
    "GitLab": "{{ cookiecutter.repo_namespace }}/{{ cookiecutter.project_slug }}",
    "Bitbucket": "{{ cookiecutter.repo_namespace }}/{{ cookiecutter.project_slug }}",
    "Azure DevOps": "{{ cookiecutter.repo_namespace }}/{{ cookiecutter.project_slug }}/_git/{{ cookiecutter.project_slug }}"
  },
  "repo_url": "{{ cookiecutter.__repo_base_urls[cookiecutter.git_service] }}/{{ cookiecutter.__repo_paths[cookiecutter.git_service] }}",
  "default_branch": "main",
  "development_branch": "develop",
  "branch_model": [
    "GitFlow",
    "GitHub Flow"
  ],
  "support_email": "support@example.com",
  "security_email": "{{ cookiecutter.support_email }}",
  "conduct_email": "{{ cookiecutter.support_email }}",
  "sponsor_url": "",
  "license_name": [
    "Apache-2.0",
    "BSD-3-Clause",
    "MIT",
    "Proprietary"
  ],
  "__year": "{% now 'local', '%Y' %}",
  "__change_request_name": "{% if cookiecutter.git_service == 'GitLab' %}merge request{% else %}pull request{% endif %}",
  "include_issue_templates": "{% if cookiecutter.git_service == 'GitHub' %}yes{% else %}no{% endif %}",
  "include_pull_request_template": "{% if cookiecutter.git_service == 'GitHub' %}yes{% else %}no{% endif %}",
  "include_release_docs": "yes",
  "include_branch_protection_docs": "yes",
  "include_maintainer_runbooks": "yes",
  "include_references": "yes",
  "include_agents_md": "yes",
  "include_funding": "{% if cookiecutter.git_service == 'GitHub' and cookiecutter.sponsor_url %}yes{% else %}no{% endif %}"
}
